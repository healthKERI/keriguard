{
  "$id": "EBgZ2DHFAGsnoTluBoigLkIGf0Wrw7sZm8ztUj4PKp7A",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wireguard Connection Credential Schema v1.0.0",
  "description": "ACDC credential schema for Wireguard VPN peer connection configuration. Defines peer-specific settings (allowedIps, endpoint, keepalive) and references two interface credentials via edges. This credential is issued to a host after interface credentials exist, enabling connection to a remote peer.",
  "credentialType": "KERIGuardConnectionDefinition",
  "type": "object",
  "required": [
    "v",
    "d",
    "u",
    "i",
    "ri",
    "s",
    "a",
    "e"
  ],
  "properties": {
    "v": {
      "description": "ACDC version string",
      "type": "string"
    },
    "d": {
      "description": "Credential SAID (Self-Addressing Identifier)",
      "type": "string"
    },
    "u": {
      "description": "UUID salty nonce for credential uniqueness",
      "type": "string"
    },
    "i": {
      "description": "Issuer AID (network administrator or credential authority)",
      "type": "string"
    },
    "ri": {
      "description": "Registry Identifier for Transaction Event Log (TEL) credential status tracking",
      "type": "string"
    },
    "s": {
      "description": "Schema SAID - must match this schema's $id",
      "type": "string"
    },
    "a": {
      "description": "Attributes block containing peer connection configuration",
      "type": "object",
      "required": [
        "d",
        "u",
        "dt"
      ],
      "properties": {
        "d": {
          "description": "Attributes block SAID",
          "type": "string"
        },
        "u": {
          "description": "Attributes block UUID nonce",
          "type": "string"
        },
        "dt": {
          "description": "Issuance datetime in ISO 8601 format",
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "e": {
      "oneOf": [
        {
          "description": "Edges block SAID",
          "type": "string"
        },
        {
          "description": "Edges block - references to peers that are to be connected (REQUIRED)",
          "type": "object",
          "required": [
            "d",
            "peer1",
            "peer2"
          ],
          "properties": {
            "d": {
              "description": "Edges block SAID",
              "type": "string"
            },
            "peer1": {
              "description": "Wireguard peer configuration for remote endpoint",
              "type": "object",
              "required": [
                "n",
                "s",
                "o",
                "allowedIps"
              ],
              "properties": {
                "n": {
                  "description": "SAID of the ACDC to which the edge connects",
                  "type": "string"
                },
                "s": {
                  "description": "Schema constraint - must be interface credential schema",
                  "type": "string",
                  "const": "ECRYEV1yPd4vnYNMqFSbTzvoxfz9iFlRMRTquU2uCAbY"
                },
                "o": {
                  "description": "Operator indicating this node is the issuer",
                  "type": "string",
                  "const": "NI2I"
                },
                "allowedIps": {
                  "description": "IP ranges allowed from the remote peer in CIDR notation",
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$|^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}/[0-9]{1,3}$"
                  },
                  "minItems": 1
                },
                "endpoint": {
                  "description": "Remote peer's endpoint in format 'host:port' (hostname or IP with port)",
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9.-]+:[0-9]{1,5}$|^\\[([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}\\]:[0-9]{1,5}$"
                },
                "persistentKeepalive": {
                  "description": "Keepalive interval in seconds (0 disables, typical value 25)",
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 65535
                },
                "presharedKey": {
                  "description": "Optional preshared key for additional post-quantum security (base64-encoded, 32 bytes)",
                  "type": "string",
                  "pattern": "^[A-Za-z0-9+/]{43}=$"
                },
                "peerName": {
                  "description": "Human-readable name for this peer",
                  "type": "string",
                  "maxLength": 128
                },
                "connectionMetadata": {
                  "description": "Metadata describing the connection purpose and characteristics",
                  "type": "object",
                  "required": [
                    "connectionName"
                  ],
                  "properties": {
                    "connectionName": {
                      "description": "Human-readable connection identifier (used for tracking and logging)",
                      "type": "string",
                      "pattern": "^[a-zA-Z0-9_-]+$",
                      "minLength": 1,
                      "maxLength": 64
                    },
                    "purpose": {
                      "description": "Purpose or description of this connection",
                      "type": "string",
                      "maxLength": 256
                    },
                    "environment": {
                      "description": "Deployment environment tag (e.g., production, staging, development)",
                      "type": "string",
                      "enum": [
                        "production",
                        "staging",
                        "development",
                        "test"
                      ]
                    },
                    "bandwidthClass": {
                      "description": "Expected bandwidth usage classification",
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high",
                        "critical"
                      ]
                    }
                  }
                }
              }
            },
            "peer2": {
              "description": "Wireguard peer configuration for remote endpoint",
              "type": "object",
              "required": [
                "n",
                "s",
                "o",
                "allowedIps"
              ],
              "properties": {
                "n": {
                  "description": "SAID of the ACDC to which the edge connects",
                  "type": "string"
                },
                "s": {
                  "description": "Schema constraint - must be interface credential schema",
                  "type": "string",
                  "const": "ECRYEV1yPd4vnYNMqFSbTzvoxfz9iFlRMRTquU2uCAbY"
                },
                "o": {
                  "description": "Operator indicating this node is the issuer",
                  "type": "string",
                  "const": "NI2I"
                },
                "allowedIps": {
                  "description": "IP ranges allowed from the remote peer in CIDR notation",
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$|^([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}/[0-9]{1,3}$"
                  },
                  "minItems": 1
                },
                "endpoint": {
                  "description": "Remote peer's endpoint in format 'host:port' (hostname or IP with port)",
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9.-]+:[0-9]{1,5}$|^\\[([0-9a-fA-F]{0,4}:){2,7}[0-9a-fA-F]{0,4}\\]:[0-9]{1,5}$"
                },
                "persistentKeepalive": {
                  "description": "Keepalive interval in seconds (0 disables, typical value 25)",
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 65535
                },
                "presharedKey": {
                  "description": "Optional preshared key for additional post-quantum security (base64-encoded, 32 bytes)",
                  "type": "string",
                  "pattern": "^[A-Za-z0-9+/]{43}=$"
                },
                "peerName": {
                  "description": "Human-readable name for this peer",
                  "type": "string",
                  "maxLength": 128
                },
                "connectionMetadata": {
                  "description": "Metadata describing the connection purpose and characteristics",
                  "type": "object",
                  "required": [
                    "connectionName"
                  ],
                  "properties": {
                    "connectionName": {
                      "description": "Human-readable connection identifier (used for tracking and logging)",
                      "type": "string",
                      "pattern": "^[a-zA-Z0-9_-]+$",
                      "minLength": 1,
                      "maxLength": 64
                    },
                    "purpose": {
                      "description": "Purpose or description of this connection",
                      "type": "string",
                      "maxLength": 256
                    },
                    "environment": {
                      "description": "Deployment environment tag (e.g., production, staging, development)",
                      "type": "string",
                      "enum": [
                        "production",
                        "staging",
                        "development",
                        "test"
                      ]
                    },
                    "bandwidthClass": {
                      "description": "Expected bandwidth usage classification",
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high",
                        "critical"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}